{
  "name": "greenbridge-loans-mcp-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx watch server/src/index.ts",
    "dev:bookshop": "tsx watch apps/server/src/index.ts",
    "build": "npm run build:loans && npm run build:bookshop",
    "build:loans": "npm run build:web && npm run build:server",
    "build:bookshop": "npm run build -w @last-bookshop/contracts && npm run build -w @last-bookshop/game-content && npm run build -w @last-bookshop/server && npm run build -w @last-bookshop/widget",
    "build:web": "vite build --config web/vite.config.ts",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node server/dist/index.js",
    "start:bookshop": "node apps/server/dist/index.js",
    "check": "npm run typecheck && npm run lint && npm test",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint apps packages vitest.config.ts",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.4.1",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.34",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.1.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^8.1.3",
    "vitest": "^4.0.15"
  }
}
